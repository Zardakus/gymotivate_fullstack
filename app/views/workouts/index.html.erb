<div class="max-w-4xl mx-auto mt-10">
  <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
    <h1 class="text-3xl font-bold text-gray-800">Fichas de Treino</h1>

    <div class="flex w-full md:w-auto gap-4">
      <!-- Formulário de Busca -->
      <%= form_with url: root_path, method: :get, class: "flex w-full md:w-80" do |f| %>
        <%= f.text_field :query, value: params[:query], placeholder: "Buscar treinos...", class: "w-full rounded-l-md border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm" %>
        <%= f.submit "Buscar", class: "bg-gray-800 text-white px-4 py-2 rounded-r-md text-sm font-medium hover:bg-gray-700 cursor-pointer" %>
      <% end %>

      <% if policy(Workout).create? %>
        <%= link_to "Nova Ficha", new_workout_path, class: "whitespace-nowrap bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      <% end %>
    </div>
  </div>

  <% if notice.present? %>
    <div data-controller="flash" class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6 rounded shadow-sm transition-all duration-500">
      <%= notice %>
    </div>
  <% end %>

  <div class="bg-white shadow overflow-hidden sm:rounded-md p-4">
    <% if @workouts.any? %>
      <ul role="list" class="divide-y divide-gray-200">
        <% @workouts.each do |workout| %>
          <li class="py-4">

            <%= turbo_frame_tag dom_id(workout) do %>
              <div class="flex justify-between space-x-3">
                <div class="flex-1 space-y-2">
                  <h3 class="text-lg font-bold text-gray-900"><%= workout.title %></h3>
                  <p class="text-sm text-gray-600"><%= workout.description %></p>

                  <% if workout.exercises.any? %>
                    <div class="mt-3 bg-gray-50 rounded p-3 border border-gray-200 mr-4">
                      <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Exercícios</h4>
                      <ul class="space-y-1">
                        <% workout.exercises.each do |exercise| %>
                          <li class="text-sm text-gray-700 flex justify-between border-b border-gray-200 pb-1 last:border-0 last:pb-0">
                            <span class="font-medium"><%= exercise.name %></span>
                            <span class="text-gray-500 text-xs">
                              <%= exercise.sets %>x<%= exercise.reps %>
                              <%= "- #{exercise.weight}" if exercise.weight.present? %>
                            </span>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>

                  <div class="mt-2 text-sm text-gray-500 flex gap-4">
                    <span><strong class="text-gray-700">Professor:</strong> <%= workout.trainer.email %></span>
                    <span><strong class="text-gray-700">Aluno:</strong> <%= workout.member.email %></span>
                  </div>
                </div>

                <div class="flex flex-col space-y-2 text-right">
                  <%= link_to "Iniciar Treino Hoje", new_workout_log_path(workout_id: workout.id), data: { turbo_frame: "_top" }, class: "bg-green-600 hover:bg-green-700 text-white text-center text-sm font-bold py-2 px-3 rounded shadow transition-colors mb-1" %>

                  <% if policy(workout).show? %>
                    <%= link_to "Baixar PDF", workout_path(workout, format: :pdf), target: "_blank", class: "text-green-600 hover:text-green-900 text-sm font-bold" %>
                  <% end %>

                  <% if policy(workout).edit? %>
                    <%= link_to "Editar", edit_workout_path(workout), class: "text-blue-600 hover:text-blue-900 text-sm font-medium" %>
                  <% end %>

                  <% if policy(workout).destroy? %>
                    <%= link_to "Excluir", workout_path(workout),
                                data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir esta ficha?" },
                                class: "text-red-600 hover:text-red-900 text-sm font-medium" %>
                  <% end %>
                </div>
              </div>
            <% end %>

          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-center text-gray-500 py-8">Nenhuma ficha de treino cadastrada ainda.</p>
    <% end %>
  </div>
  <!-- Renderiza os botões do Pagy se houver mais de uma página -->
  <% if @pagy.pages > 1 %>
    <div class="mt-8 flex justify-center">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
