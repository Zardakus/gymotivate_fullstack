<%= turbo_frame_tag dom_id(@workout) do %>

  <div class="bg-blue-50 p-4 rounded-md border border-blue-200 w-full">
    <%= form_with model: @workout, class: "space-y-4" do |form| %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= form.label :title, "Título", class: "block text-xs font-bold text-gray-700" %>
          <%= form.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-1 px-2 text-gray-900" %>
        </div>

        <div>
          <%= form.label :trainer_id, "Professor", class: "block text-xs font-bold text-gray-700" %>
          <%= form.collection_select :trainer_id, current_user.gym.users.where(role: :trainer), :id, :email, {}, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm py-1 px-2 text-gray-900" } %>
        </div>
      </div>

      <!-- Bloco de Exercícios na Edição Inline -->
      <div class="bg-white p-3 rounded border border-blue-200">
        <h4 class="text-xs font-bold text-gray-700 mb-2">Exercícios do Treino</h4>
        <div class="space-y-2">
          <%= form.fields_for :exercises do |exercise_form| %>
            <div class="grid grid-cols-12 gap-1 items-center">
              <div class="col-span-3">
                <%= exercise_form.text_field :name, placeholder: "Nome", class: "block w-full rounded border border-gray-300 text-xs px-2 py-1" %>
              </div>
              <div class="col-span-3">
                <%= exercise_form.select :muscle_group, ["Peito", "Costas", "Pernas", "Ombros", "Braços", "Core", "Cardio"], { prompt: "Músculo" }, class: "block w-full rounded border border-gray-300 text-[11px] px-1 py-1" %>
              </div>
              <div class="col-span-2">
                <%= exercise_form.number_field :sets, placeholder: "Séries", class: "block w-full rounded border border-gray-300 text-xs px-2 py-1" %>
              </div>
              <div class="col-span-2">
                <%= exercise_form.text_field :reps, placeholder: "Reps", class: "block w-full rounded border border-gray-300 text-xs px-2 py-1" %>
              </div>
              <div class="col-span-2 flex items-center justify-between">
                <%= exercise_form.text_field :weight, placeholder: "Carga", class: "block w-full rounded border border-gray-300 text-xs px-2 py-1" %>

                <!-- Checkbox de exclusão se o exercício já existe no banco -->
                <% if exercise_form.object.persisted? %>
                  <div class="ml-2" title="Marque para excluir este exercício">
                    <%= exercise_form.check_box :_destroy, class: "h-4 w-4 text-red-600 rounded border-gray-300 cursor-pointer" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div>
        <%= form.label :description, "Descrição", class: "block text-xs font-bold text-gray-700" %>
        <%= form.text_area :description, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-1 px-2 text-gray-900" %>
      </div>

      <div class="flex justify-end space-x-2 pt-2">
        <%= link_to "Cancelar", request.referer || root_path, data: { turbo_frame: "_top" }, class: "text-gray-600 hover:text-gray-900 text-sm font-bold py-1 px-3" %>
        <%= form.submit "Atualizar Ficha", class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold py-1 px-4 rounded cursor-pointer" %>
      </div>
    <% end %>
  </div>

<% end %>
