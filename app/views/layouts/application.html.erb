<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Gymotivate" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

<body class="bg-gray-100 antialiased font-sans flex h-screen overflow-hidden">

    <% if user_signed_in? %>
      <aside class="w-64 bg-gray-900 text-white flex flex-col hidden md:flex">
        <div class="h-16 flex items-center justify-center border-b border-gray-800">
          <h1 class="text-xl font-bold text-blue-500 uppercase tracking-wider">Gymotivate</h1>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">

          <!-- Link para Treinos dinâmico -->
          <%= link_to root_path, class: "flex items-center px-4 py-3 rounded-md transition-colors #{current_page?(root_path) ? 'bg-gray-800 text-white font-medium' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5 mr-3 #{current_page?(root_path) ? 'text-blue-400' : 'text-current'}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            Fichas de Treino
          <% end %>

          <!-- Link para Dashboard dinâmico -->
          <%= link_to dashboard_path, class: "flex items-center px-4 py-3 rounded-md transition-colors #{current_page?(dashboard_path) ? 'bg-gray-800 text-white font-medium' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-5 h-5 mr-3 #{current_page?(dashboard_path) ? 'text-blue-400' : 'text-current'}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            Dashboard
          <% end %>

          <!-- Link para Gestão dinâmico (Protegido pelo Pundit) -->
          <% if policy(User).index? %>
            <%= link_to users_path, class: "flex items-center px-4 py-3 rounded-md transition-colors #{current_page?(users_path) ? 'bg-gray-800 text-white font-medium' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3 #{current_page?(users_path) ? 'text-blue-400' : 'text-current'}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
              Gestão de Equipe
            <% end %>
          <% end %>

        </nav>

        <div class="p-4 border-t border-gray-800">
          <div class="text-sm truncate mb-1">
            <span class="text-gray-400">Logado como:</span><br>
            <strong class="text-white"><%= current_user.name || current_user.email %></strong>
          </div>
          <div class="text-xs text-blue-400 mb-4 uppercase font-bold tracking-wide">
            <%= current_user.role %> | <%= current_user.gym.name %>
          </div>
          <%= button_to "Sair do Sistema", destroy_user_session_path, method: :delete, class: "w-full text-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-bold rounded transition-colors" %>
        </div>
      </aside>
    <% end %>

    <main class="flex-1 overflow-y-auto bg-gray-100 p-8">
      <%= yield %>
    </main>

  </body>
</html>
