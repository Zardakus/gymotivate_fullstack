<div class="max-w-6xl mx-auto mt-4">
  <div class="mb-8 border-b border-gray-200 pb-4">
    <h1 class="text-3xl font-bold text-gray-900">Visão Geral da Academia</h1>
    <p class="text-sm text-gray-500 mt-1">Estatísticas em tempo real da unidade <%= current_user.gym.name %></p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-blue-500">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-blue-100 text-blue-600 mr-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        </div>
        <div>
          <p class="text-sm text-gray-500 font-medium">Fichas Criadas</p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_workouts %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-green-100 text-green-600 mr-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </div>
        <div>
          <p class="text-sm text-gray-500 font-medium">Alunos Ativos</p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_members %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-purple-500">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-purple-100 text-purple-600 mr-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        </div>
        <div>
          <p class="text-sm text-gray-500 font-medium">Professores</p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_trainers %></p>
        </div>
      </div>
    </div>

  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden border border-gray-200">
    <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-bold text-gray-800">Fichas Criadas por Professor</h3>
    </div>

    <% if @workouts_by_trainer.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-white">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Professor Responsável</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total de Fichas</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @workouts_by_trainer.each do |trainer_name, count| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= trainer_name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right font-bold"><%= count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-8 text-center text-gray-500 text-sm">
        Nenhum dado de produtividade disponível no momento.
      </div>
    <% end %>
  </div>
</div>
